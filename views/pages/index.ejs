<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= title %></title>
  <meta name="description" content="Ungkap URL asli di balik short link. Lihat redirect chain lengkap, status code tiap hop, dan indikasi keamanan — tanpa harus membuka link." />
  <meta name="theme-color" content="#0f0f17" />

  <!-- Google Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />

  <!-- Tailwind CSS CDN -->
  <script src="https://cdn.tailwindcss.com"></script>
  <script>
    tailwind.config = {
      theme: {
        extend: {
          fontFamily: {
            sans: ['Inter', 'sans-serif'],
            mono: ['JetBrains Mono', 'monospace'],
          },
          colors: {
            surface: {
              DEFAULT: '#0f0f17',
              100: '#16161f',
              200: '#1c1c28',
              300: '#242433',
            },
            brand: {
              DEFAULT: '#7c6ff7',
              light: '#a89ef9',
              dark: '#5a4fe0',
              glow: 'rgba(124,111,247,0.25)',
            },
          },
          animation: {
            'fade-in': 'fadeIn 0.4s ease-out',
            'slide-up': 'slideUp 0.4s ease-out',
            'pulse-slow': 'pulse 3s cubic-bezier(0.4,0,0.6,1) infinite',
          },
          keyframes: {
            fadeIn: { from: { opacity: 0 }, to: { opacity: 1 } },
            slideUp: { from: { opacity: 0, transform: 'translateY(16px)' }, to: { opacity: 1, transform: 'translateY(0)' } },
          },
        },
      },
    };
  </script>

  <style>
    /* Global */
    *, *::before, *::after { box-sizing: border-box; }
    html { scroll-behavior: smooth; }
    body {
      background-color: #0f0f17;
      color: #e2e2ef;
      font-family: 'Inter', sans-serif;
      min-height: 100vh;
    }

    /* Gradient orb background */
    .bg-orb {
      position: fixed;
      border-radius: 50%;
      filter: blur(120px);
      pointer-events: none;
      z-index: 0;
    }

    /* Glassmorphism card */
    .glass-card {
      background: rgba(22, 22, 31, 0.85);
      border: 1px solid rgba(255,255,255,0.07);
      backdrop-filter: blur(16px);
      -webkit-backdrop-filter: blur(16px);
      border-radius: 16px;
    }

    /* Input */
    .url-input {
      background: rgba(255,255,255,0.04);
      border: 1.5px solid rgba(255,255,255,0.1);
      color: #e2e2ef;
      border-radius: 12px;
      font-size: 0.95rem;
      transition: border-color 0.2s, box-shadow 0.2s;
    }
    .url-input:focus {
      outline: none;
      border-color: #7c6ff7;
      box-shadow: 0 0 0 3px rgba(124,111,247,0.2);
    }
    .url-input::placeholder { color: rgba(226,226,239,0.3); }

    /* Primary button */
    .btn-primary {
      background: linear-gradient(135deg, #7c6ff7 0%, #5a4fe0 100%);
      color: #fff;
      font-weight: 600;
      border-radius: 12px;
      transition: transform 0.15s, box-shadow 0.15s, opacity 0.15s;
      box-shadow: 0 4px 20px rgba(124,111,247,0.3);
    }
    .btn-primary:hover:not(:disabled) {
      transform: translateY(-1px);
      box-shadow: 0 6px 28px rgba(124,111,247,0.45);
    }
    .btn-primary:active:not(:disabled) { transform: translateY(0); }
    .btn-primary:disabled { opacity: 0.55; cursor: not-allowed; }

    /* Status code badge colors */
    .badge-2xx { background: rgba(16,185,129,0.15); color: #34d399; border: 1px solid rgba(52,211,153,0.25); }
    .badge-3xx { background: rgba(251,191,36,0.12); color: #fbbf24; border: 1px solid rgba(251,191,36,0.25); }
    .badge-4xx { background: rgba(239,68,68,0.12); color: #f87171; border: 1px solid rgba(239,68,68,0.25); }
    .badge-5xx { background: rgba(239,68,68,0.12); color: #f87171; border: 1px solid rgba(239,68,68,0.25); }

    /* Safety badge */
    .badge-safe    { background: rgba(16,185,129,0.15); color: #34d399; border: 1px solid rgba(52,211,153,0.3); }
    .badge-warning { background: rgba(239,68,68,0.12); color: #f87171; border: 1px solid rgba(239,68,68,0.3); }
    .badge-unknown { background: rgba(148,163,184,0.1); color: #94a3b8; border: 1px solid rgba(148,163,184,0.2); }

    /* Redirect chain connector */
    .chain-connector {
      width: 2px;
      background: linear-gradient(to bottom, rgba(124,111,247,0.4), rgba(124,111,247,0.1));
      margin: 0 auto;
    }

    /* Copy button */
    .btn-copy {
      background: rgba(124,111,247,0.12);
      border: 1px solid rgba(124,111,247,0.25);
      color: #a89ef9;
      border-radius: 8px;
      font-size: 0.8rem;
      font-weight: 500;
      transition: background 0.2s, color 0.2s, transform 0.1s;
    }
    .btn-copy:hover {
      background: rgba(124,111,247,0.22);
      color: #c4bafc;
    }
    .btn-copy:active { transform: scale(0.97); }

    /* History */
    .history-item {
      padding: 10px 14px;
      border-radius: 10px;
      background: rgba(255,255,255,0.03);
      border: 1px solid rgba(255,255,255,0.06);
      cursor: pointer;
      transition: background 0.15s, border-color 0.15s;
    }
    .history-item:hover {
      background: rgba(124,111,247,0.08);
      border-color: rgba(124,111,247,0.2);
    }
    .history-item-inner { display: flex; justify-content: space-between; align-items: center; gap: 8px; flex-wrap: wrap; }
    .history-urls { display: flex; align-items: center; gap: 6px; font-size: 0.8rem; flex-wrap: wrap; }
    .history-input { color: #94a3b8; font-family: 'JetBrains Mono', monospace; }
    .history-final { color: #a89ef9; font-family: 'JetBrains Mono', monospace; }
    .history-arrow { width: 12px; height: 12px; color: #4b5563; flex-shrink: 0; }
    .history-meta { display: flex; gap: 8px; font-size: 0.72rem; color: #6b7280; white-space: nowrap; }
    .history-hops { background: rgba(124,111,247,0.1); color: #7c6ff7; padding: 1px 6px; border-radius: 4px; }

    /* Loading spinner */
    @keyframes spin { to { transform: rotate(360deg); } }
    .spinner { animation: spin 0.8s linear infinite; }

    /* Navbar */
    .navbar {
      background: rgba(15,15,23,0.85);
      border-bottom: 1px solid rgba(255,255,255,0.06);
      backdrop-filter: blur(12px);
      -webkit-backdrop-filter: blur(12px);
    }

    /* URL text in mono */
    .url-mono {
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.85rem;
      word-break: break-all;
    }

    /* Fade/slide animation trigger */
    .animate-result { animation: slideUp 0.4s ease-out; }
  </style>
</head>
<body>

  <!-- Background orbs -->
  <div class="bg-orb w-96 h-96 opacity-20" style="background:#7c6ff7; top:-6rem; left:-6rem;"></div>
  <div class="bg-orb w-80 h-80 opacity-10" style="background:#5eead4; bottom:0; right:-4rem;"></div>

  <!-- Navbar -->
  <nav class="navbar sticky top-0 z-50">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 h-14 flex items-center justify-between">
      <a href="/" class="flex items-center gap-2 group">
        <div class="w-7 h-7 rounded-lg bg-gradient-to-br from-brand to-brand-dark flex items-center justify-center">
          <svg class="w-4 h-4 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1"/>
          </svg>
        </div>
        <span class="font-bold text-white text-sm tracking-tight group-hover:text-brand-light transition-colors">Reveal Link</span>
      </a>
      <div class="flex items-center gap-1">
        <a href="/" class="px-3 py-1.5 rounded-lg text-sm font-medium text-slate-400 hover:text-white hover:bg-white/5 transition-all">Home</a>
        <a href="/about" class="px-3 py-1.5 rounded-lg text-sm font-medium text-slate-400 hover:text-white hover:bg-white/5 transition-all">Tentang</a>
      </div>
    </div>
  </nav>

  <main class="relative z-10 max-w-4xl mx-auto px-4 sm:px-6 py-12 sm:py-16">
    
    <!-- Hero -->
    <div class="text-center mb-10">
      <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full text-xs font-medium mb-5" style="background:rgba(124,111,247,0.12);color:#a89ef9;border:1px solid rgba(124,111,247,0.25);">
        <span class="w-1.5 h-1.5 rounded-full bg-brand-light animate-pulse-slow inline-block"></span>
        URL Unshortener Gratis
      </div>
      <h1 class="text-3xl sm:text-5xl font-extrabold text-white tracking-tight leading-tight mb-4">
        Ungkap URL Asli di<br/>
        <span style="background:linear-gradient(135deg,#7c6ff7,#a89ef9,#5eead4);-webkit-background-clip:text;-webkit-text-fill-color:transparent;">Balik Short Link</span>
      </h1>
      <p class="text-slate-400 text-base sm:text-lg max-w-lg mx-auto leading-relaxed">
        Tempel short link (bit.ly, tinyurl, t.co, dll) dan lihat ke mana sebenarnya link itu mengarah — beserta seluruh jejak redirect-nya.
      </p>
    </div>

    <!-- Input Card -->
    <div class="glass-card p-6 sm:p-8 mb-6">
      <form id="check-form" novalidate>
        <label for="url-input" class="block text-sm font-medium text-slate-300 mb-2">
          Masukkan Short Link
        </label>
        <div class="flex flex-col sm:flex-row gap-3">
          <input
            id="url-input"
            type="url"
            name="url"
            class="url-input flex-1 px-4 py-3"
            placeholder="https://bit.ly/contoh-link"
            autocomplete="off"
            spellcheck="false"
          />
          <button
            id="submit-btn"
            type="button"
            onclick="checkUrl()"
            class="btn-primary px-6 py-3 text-sm flex items-center justify-center gap-2 whitespace-nowrap"
          >
            <svg id="btn-icon" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
            </svg>
            <span id="btn-text">Cek Link</span>
          </button>
        </div>
        <p class="text-xs text-slate-500 mt-2.5">
          Kami tidak menyimpan link yang Anda masukkan. Maks. 10 redirect hop, timeout 5 detik/hop.
        </p>
      </form>
    </div>

    <!-- Dynamic result / error container (populated by axios) -->
    <div id="result-container"></div>


    <!-- History Section -->
    <div id="history-section" class="hidden mt-8">
      <div class="flex items-center justify-between mb-3">
        <h2 class="text-sm font-semibold text-slate-400 flex items-center gap-2">
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
          </svg>
          Riwayat Pengecekan
        </h2>
        <button
          onclick="window.RevealHistory.clearHistory()"
          class="text-xs text-slate-600 hover:text-slate-400 transition-colors"
        >
          Hapus Semua
        </button>
      </div>
      <ul id="history-list" class="space-y-2"></ul>
    </div>

  </main>

  <!-- Footer -->
  <footer class="relative z-10 border-t border-white/5 mt-16 py-8">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 text-center">
      <p class="text-xs text-slate-600"> 
        Tidak ada data URL yang disimpan di server.
      </p>
    </div>
  </footer>

  <!-- History JS -->
  <script src="/js/history.js"></script>

  <!-- axios CDN -->
  <script src="https://cdn.jsdelivr.net/npm/axios/dist/axios.min.js"></script>

  <script>
    // ─── Helpers ───────────────────────────────────────────────────────────────

    const ICON_SEARCH = `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>`;
    const ICON_SPIN   = `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/>`;
    const ICON_COPY   = `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z"/>`;
    const ICON_CHECK  = `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/>`;

    function setLoading(loading) {
      const btn     = document.getElementById('submit-btn');
      const btnText = document.getElementById('btn-text');
      const btnIcon = document.getElementById('btn-icon');
      btn.disabled          = loading;
      btnText.textContent   = loading ? 'Memproses…' : 'Cek Link';
      btnIcon.innerHTML     = loading ? ICON_SPIN : ICON_SEARCH;
      loading ? btnIcon.classList.add('animate-spin') : btnIcon.classList.remove('animate-spin');
    }

    function escapeHtml(str) {
      return String(str)
        .replace(/&/g, '&amp;')
        .replace(/</g, '&lt;')
        .replace(/>/g, '&gt;')
        .replace(/"/g, '&quot;');
    }

    function badgeClass(sc) {
      if (sc >= 200 && sc < 300) return 'badge-2xx';
      if (sc >= 300 && sc < 400) return 'badge-3xx';
      if (sc >= 400 && sc < 500) return 'badge-4xx';
      return 'badge-5xx';
    }

    function safetyBadgeClass(status) {
      if (status === 'safe')    return 'badge-safe';
      if (status === 'warning') return 'badge-warning';
      return 'badge-unknown';
    }

    function safetyIcon(status) {
      if (status === 'safe') return `<svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>`;
      if (status === 'warning') return `<svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z"/></svg>`;
      return `<svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8.228 9c.549-1.165 2.03-2 3.772-2 2.21 0 4 1.343 4 3 0 1.4-1.278 2.575-3.006 2.907-.542.104-.994.54-.994 1.093m0 3h.01"/></svg>`;
    }

    // ─── Render helpers ────────────────────────────────────────────────────────

    function renderError(error) {
      const hint = error.code === 'INVALID_URL'
        ? `<p class="text-xs text-slate-500 mt-1">Pastikan URL diawali dengan <code class="text-slate-400">http://</code> atau <code class="text-slate-400">https://</code></p>`
        : '';
      return `
        <div class="animate-result glass-card p-5 mb-6 flex items-start gap-4"
             style="border-color:rgba(239,68,68,0.25);background:rgba(239,68,68,0.05);">
          <div class="mt-0.5 w-8 h-8 rounded-lg flex items-center justify-center flex-shrink-0"
               style="background:rgba(239,68,68,0.15);">
            <svg class="w-4 h-4 text-red-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                    d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
            </svg>
          </div>
          <div>
            <p class="font-semibold text-red-400 text-sm mb-0.5">Gagal Memproses Link</p>
            <p class="text-sm text-slate-400">${escapeHtml(error.message)}</p>
            ${hint}
          </div>
        </div>`;
    }

    function renderResult(result, inputUrl) {
      const { finalUrl, chain, safety, metadata } = result;
      const s = safety || { status: 'unknown', label: 'Tidak Diketahui', detail: '' };

      // Metadata preview
      const metaHtml = (metadata && (metadata.title || metadata.faviconUrl)) ? `
        <div class="flex items-center gap-3 mb-4 p-3 rounded-xl"
             style="background:rgba(255,255,255,0.03);border:1px solid rgba(255,255,255,0.06);">
          ${metadata.faviconUrl ? `<img src="${escapeHtml(metadata.faviconUrl)}" alt="favicon" class="w-5 h-5 rounded object-contain flex-shrink-0" onerror="this.style.display='none'"/>` : ''}
          ${metadata.title ? `<span class="text-sm text-slate-300 truncate">${escapeHtml(metadata.title)}</span>` : ''}
        </div>` : '';

      // Safety disclaimer
      const safetyNote = s.detail ? `
        <p class="text-xs text-slate-500 mt-2.5 flex items-center gap-1">
          <svg class="w-3 h-3 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                  d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
          </svg>
          ${escapeHtml(s.detail)} Hasil pemeriksaan bersifat indikatif, bukan jaminan keamanan mutlak.
        </p>` : '';

      // Redirect chain hops
      const chainHtml = chain.map((hop, i) => {
        const isLast  = i === chain.length - 1;
        const hopBadge = badgeClass(hop.statusCode);
        const numClass = isLast
          ? 'bg-emerald-500/20 text-emerald-400 border border-emerald-500/30'
          : 'bg-brand/10 text-brand border border-brand/20';
        const connector = isLast ? '' : `<div class="chain-connector h-6 w-px my-1"></div>`;
        const lastLabel  = isLast ? `<span class="text-xs text-emerald-400 font-medium">Tujuan Akhir</span>` : '';
        return `
          <li>
            <div class="flex items-start gap-3">
              <div class="flex flex-col items-center flex-shrink-0">
                <div class="w-7 h-7 rounded-full flex items-center justify-center text-xs font-bold flex-shrink-0 ${numClass}">${i + 1}</div>
                ${connector}
              </div>
              <div class="flex-1 ${isLast ? '' : 'pb-2'}">
                <div class="flex items-center gap-2 flex-wrap">
                  <span class="text-xs font-semibold px-2 py-0.5 rounded-md font-mono ${hopBadge}">${hop.statusCode}</span>
                  ${lastLabel}
                </div>
                <p class="url-mono text-slate-300 mt-1.5 text-sm leading-snug hover:text-white transition-colors">${escapeHtml(hop.url)}</p>
              </div>
            </div>
          </li>`;
      }).join('');

      return `
        <div class="animate-result space-y-5">

          <!-- Final URL Card -->
          <div class="glass-card p-6">
            <div class="flex items-center gap-2 mb-4">
              <div class="w-6 h-6 rounded-md flex items-center justify-center" style="background:rgba(16,185,129,0.15);">
                <svg class="w-3.5 h-3.5 text-emerald-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/>
                </svg>
              </div>
              <span class="text-sm font-semibold text-emerald-400">URL Final Ditemukan</span>
              <span class="ml-auto text-xs font-medium px-2.5 py-1 rounded-full flex items-center gap-1.5 ${safetyBadgeClass(s.status)}">
                ${safetyIcon(s.status)} ${escapeHtml(s.label)}
              </span>
            </div>
            ${metaHtml}
            <div class="flex items-center gap-3 p-4 rounded-xl" style="background:rgba(124,111,247,0.06);border:1px solid rgba(124,111,247,0.15);">
              <p id="final-url" class="url-mono flex-1 text-brand-light">${escapeHtml(finalUrl)}</p>
              <div class="flex gap-2 flex-shrink-0">
                <button id="copy-btn" onclick="copyFinalUrl()" class="btn-copy px-3 py-1.5 flex items-center gap-1.5" title="Salin URL">
                  <svg id="copy-icon" class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">${ICON_COPY}</svg>
                  <span id="copy-text">Salin</span>
                </button>
                <a href="${escapeHtml(finalUrl)}" target="_blank" rel="noopener noreferrer"
                   class="btn-copy px-3 py-1.5 flex items-center gap-1.5" title="Buka link">
                  <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/>
                  </svg>
                  Buka
                </a>
              </div>
            </div>
            ${safetyNote}
          </div>

          <!-- Redirect Chain Card -->
          <div class="glass-card p-6">
            <div class="flex items-center justify-between mb-5">
              <h2 class="text-sm font-semibold text-white flex items-center gap-2">
                <svg class="w-4 h-4 text-brand" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h7"/>
                </svg>
                Redirect Chain
              </h2>
              <span class="text-xs text-slate-500 font-mono">${chain.length} hop</span>
            </div>
            <ol class="space-y-0">${chainHtml}</ol>
          </div>

        </div>`;
    }

    // ─── Main: check URL via axios ─────────────────────────────────────────────

    async function checkUrl() {
      const input     = document.getElementById('url-input');
      const container = document.getElementById('result-container');
      const inputUrl  = input.value.trim();

      if (!inputUrl) {
        container.innerHTML = renderError({ code: 'INVALID_URL', message: 'URL tidak boleh kosong.' });
        container.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
        return;
      }

      setLoading(true);
      container.innerHTML = '';

      try {
        const { data } = await axios.post('/check', { url: inputUrl }, {
          headers: { 'Content-Type': 'application/json' },
        });

        if (data.success) {
          container.innerHTML = renderResult(data.result, inputUrl);
          // Save to localStorage history
          if (window.RevealHistory) {
            window.RevealHistory.saveEntry(inputUrl, data.result.finalUrl, data.result.chain.length);
          }
        } else {
          container.innerHTML = renderError(data.error);
        }
      } catch (err) {
        const apiError = err.response?.data?.error;
        container.innerHTML = renderError(
          apiError || { code: 'UNKNOWN', message: 'Terjadi kesalahan tidak terduga. Silakan coba lagi.' }
        );
      } finally {
        setLoading(false);
        container.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
      }
    }

    // Allow pressing Enter in the input field
    document.getElementById('url-input').addEventListener('keydown', (e) => {
      if (e.key === 'Enter') checkUrl();
    });

    // ─── Copy to clipboard ─────────────────────────────────────────────────────

    async function copyFinalUrl() {
      const url = document.getElementById('final-url')?.textContent?.trim();
      if (!url) return;
      try {
        await navigator.clipboard.writeText(url);
        document.getElementById('copy-text').textContent = 'Tersalin!';
        document.getElementById('copy-icon').innerHTML   = ICON_CHECK;
        setTimeout(() => {
          const ct = document.getElementById('copy-text');
          const ci = document.getElementById('copy-icon');
          if (ct) ct.textContent = 'Salin';
          if (ci) ci.innerHTML   = ICON_COPY;
        }, 2000);
      } catch {
        const ta = document.createElement('textarea');
        ta.value = url;
        document.body.appendChild(ta);
        ta.select();
        document.execCommand('copy');
        document.body.removeChild(ta);
      }
    }
  </script>

</body>
</html>
